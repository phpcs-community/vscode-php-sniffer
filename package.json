{
    "name": "php-codesniffer",
    "displayName": "PHP_CodeSniffer Community",
    "description": "Community-maintained VS Code extension for PHP_CodeSniffer — real-time linting and auto-fix for PHP, powered by phpcs and phpcbf.",
    "version": "2.0.2",
    "engines": {
        "vscode": "^1.90.0"
    },
    "publisher": "phpcscommunity",
    "icon": "icon.png",
    "license": "MIT",
    "categories": [
        "Formatters",
        "Linters"
    ],
    "keywords": [
        "php",
        "phpcs",
        "phpcbf",
        "php-codesniffer",
        "linter",
        "formatter",
        "beautifier",
        "code style"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/phpcs-community/vscode-php-sniffer"
    },
    "homepage": "https://github.com/phpcs-community/vscode-php-sniffer#readme",
    "bugs": {
        "url": "https://github.com/phpcs-community/vscode-php-sniffer/issues"
    },
    "activationEvents": [
        "onLanguage:php",
        "workspaceContains:**/phpcs.xml",
        "workspaceContains:**/.phpcs.xml",
        "workspaceContains:**/phpcs.xml.dist",
        "workspaceContains:**/.phpcs.xml.dist"
    ],
    "main": "./extension",
    "contributes": {
        "commands": [
            {
                "command": "phpSniffer.showOutput",
                "title": "PHP Sniffer: Show Output Channel"
            },
            {
                "command": "phpSniffer.runLint",
                "title": "PHP Sniffer: Run Lint"
            },
            {
                "command": "phpSniffer.fixFile",
                "title": "PHP Sniffer: Fix File"
            },
            {
                "command": "phpSniffer.copyDebugInfo",
                "title": "PHP Sniffer: Copy Debug Info"
            }
        ],
        "problemMatchers": [
            {
                "name": "phpcs",
                "label": "PHP CodeSniffer",
                "owner": "phpcs",
                "fileLocation": "absolute",
                "pattern": [
                    {
                        "regexp": "^FILE: (.+)$",
                        "file": 1
                    },
                    {
                        "regexp": "^\\s*(\\d+)\\s+\\|\\s+(ERROR|WARNING)\\s+\\|\\s+(?:\\[x\\]\\s+)?(.+)$",
                        "line": 1,
                        "severity": 2,
                        "message": 3,
                        "loop": true
                    }
                ]
            }
        ],
        "configuration": {
            "type": "object",
            "title": "PHP Sniffer",
            "properties": {
                "phpSniffer.run": {
                    "type": "string",
                    "default": "onSave",
                    "enum": [
                        "onSave",
                        "onType",
                        "never"
                    ],
                    "markdownEnumDescriptions": [
                        "Run `phpcs` on save.",
                        "Run `phpcs` after typing after `<onTypeDelay>`milliseconds.",
                        "Don't run `phpcs` ever."
                    ],
                    "markdownDescription": "When to run `phpcs`."
                },
                "phpSniffer.onTypeDelay": {
                    "type": "number",
                    "default": 250,
                    "minimum": 0,
                    "markdownDescription": "When `#phpSniffer.run#` is `onType`, this sets the amount of milliseconds the validator will wait after typing has stopped before it will run."
                },
                "phpSniffer.maxConcurrentProcesses": {
                    "type": "number",
                    "default": 4,
                    "minimum": 0,
                    "markdownDescription": "Maximum number of concurrent `phpcs` processes. Set to `0` for unlimited."
                },
                "phpSniffer.extraFiles": {
                    "type": "array",
                    "uniqueItems": true,
                    "default": [],
                    "markdownDescription": "[Glob patterns](https://code.visualstudio.com/api/references/vscode-api#GlobPattern) of extra files to match that this extension should run on. Useful for standards that don't just validate PHP files.",
                    "items": {
                        "type": "string"
                    }
                },
                "phpSniffer.executablesFolder": {
                    "scope": "resource",
                    "type": "string",
                    "default": "",
                    "markdownDescription": "Use this to specify a different executables folder if it is not in your global `PATH`, such as when using `PHP_Codesniffer` as a project-scoped dependency. Can be absolute, or relative to the workspace folder."
                },
                "phpSniffer.autoDetect": {
                    "scope": "resource",
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "Set to `true` for the extension to auto-detect `phpSniffer.executablesFolder` as `./vendor/bin/` per workspace folder (applies only if `phpSniffer.executablesFolder` is empty)."
                },
                "phpSniffer.standard": {
                    "scope": "resource",
                    "type": "string",
                    "default": "",
                    "markdownDescription": "The standards to check against. This is passed to the `phpcbf` and `phpcs` executables as the value for `--standard`. Can be absolute, or relative to the workspace folder. If not set, [PHP_CodeSniffer will attempt to find a file to use](https://github.com/PHPCSStandards/PHP_CodeSniffer/wiki/Advanced-Usage#using-a-default-configuration-file)."
                },
                "phpSniffer.snippetExcludeSniffs": {
                    "scope": "resource",
                    "type": "array",
                    "default": [],
                    "markdownDescription": "Sniffs to exclude when formatting a code snippet (such as when _formatting on paste_ or on the command `format on selection`). This is passed to the `phpcbf` command as the value for `--exclude` when **not** formatting a whole file."
                },
                "phpSniffer.disableWhenDebugging": {
                    "scope": "machine",
                    "type": "boolean",
                    "default": false,
                    "description": "Disable sniffing when any debug session is active."
                },
                "phpSniffer.maxFileSize": {
                    "scope": "resource",
                    "type": "number",
                    "default": 0,
                    "minimum": 0,
                    "markdownDescription": "Maximum file size in kilobytes to lint. Files larger than this will be skipped. Set to `0` to disable the limit."
                },
                "phpSniffer.timeout": {
                    "scope": "resource",
                    "type": "number",
                    "default": 30,
                    "minimum": 0,
                    "markdownDescription": "Maximum time in seconds to wait for `phpcs`/`phpcbf` before killing the process. Set to `0` to disable."
                },
                "phpSniffer.logLevel": {
                    "type": "string",
                    "default": "error",
                    "enum": [
                        "off",
                        "error",
                        "info",
                        "debug"
                    ],
                    "enumDescriptions": [
                        "Disable all logging.",
                        "Log errors only.",
                        "Log errors and informational messages.",
                        "Log everything including PHPCS commands and arguments."
                    ],
                    "description": "Controls the verbosity of the PHP CodeSniffer output channel."
                },
                "phpSniffer.fixOnSave": {
                    "type": "boolean",
                    "default": false,
                    "description": "Automatically fix PHP files with PHPCBF when saving."
                },
                "phpSniffer.showOutputOnError": {
                    "type": "boolean",
                    "default": true,
                    "description": "Automatically reveal the PHP CodeSniffer output channel when an error occurs."
                },
                "phpSniffer.workingDirectory": {
                    "scope": "resource",
                    "type": "string",
                    "default": "auto",
                    "enum": [
                        "auto",
                        "workspaceRoot",
                        "fileDir"
                    ],
                    "enumDescriptions": [
                        "Use the workspace folder root (or the file's directory if no workspace is open).",
                        "Always use the workspace folder root.",
                        "Always use the directory of the file being checked."
                    ],
                    "markdownDescription": "Controls the working directory passed to `phpcs`/`phpcbf`."
                },
                "phpSniffer.previewFix": {
                    "type": "boolean",
                    "default": false,
                    "description": "Show a diff preview before applying PHPCBF fixes instead of applying immediately."
                }
            }
        }
    },
    "scripts": {
        "format": "prettier --write .",
        "lint": "prettier --check . && eslint --ignore-path .gitignore . && tsc",
        "test:unit": "mocha \"./test/unit/*.test.js\"",
        "test:integration": "node ./test/run.js",
        "version": "node ./scripts/changelog && git add CHANGELOG.md",
        "publish:vsce": "npx @vscode/vsce publish",
        "publish:ovsx": "npx ovsx publish"
    },
    "devDependencies": {
        "@types/lodash.debounce": "^4.0.9",
        "@types/node": "^25.5.0",
        "@types/vscode": "^1.90.0",
        "@vscode/test-electron": "^2.4.0",
        "eslint": "^8.57.0",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.29.0",
        "fs-extra": "^11.0.0",
        "get-stdin": "^9.0.0",
        "glob": "^10.0.0",
        "mocha": "^10.0.0",
        "prettier": "^3.8.1",
        "typescript": "^5.0.0"
    },
    "dependencies": {
        "lodash.debounce": "^4.0.8"
    }
}
